# ═══════════════════════════════════════════════════
# ZAPKART BACKEND — Environment Variables
# ═══════════════════════════════════════════════════
# Fill in ALL values below. The server will NOT start
# until every variable has a value.
# NEVER commit this file to Git.
# ═══════════════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Supabase (Service Role — Full Database Access) ──
# Go to: https://supabase.com → Your Project → Settings → API
# Use the "service_role" key here (NOT the anon key):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Firebase Admin SDK ──
# Go to: https://console.firebase.google.com → Project Settings → Service accounts
# Click "Generate new private key" to download the JSON file
# Then fill in these values from that JSON file:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── CORS ──
# Frontend URL (admin panel origin):
CORS_ORIGIN=http://localhost:5173

# ── Redis ──
# Upstash Redis secure URL (rediss://default:TOKEN@host:port)
REDIS_URL=rediss://default:your-token-here@your-upstash-endpoint.upstash.io:6379
