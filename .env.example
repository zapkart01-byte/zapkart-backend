# ═══════════════════════════════════════════════════
# ZAPKART BACKEND — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env file to Git - only .env.example
# ═══════════════════════════════════════════════════

# ── Server ──
PORT=3000
NODE_ENV=development

# ── Supabase (Service Role — Full Database Access) ──
# Go to: https://supabase.com → Your Project → Settings → API
# Use the "service_role" key here (NOT the anon key):
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ── Firebase (ONLY for FCM Push Notifications) ──
# Go to: https://console.firebase.google.com → Project Settings → Service accounts
# Click "Generate new private key" to download the JSON file
# Copy these values from that JSON file:
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── CORS ──
# Frontend URLs (comma-separated, no spaces):
CORS_ORIGIN=http://localhost:5173,https://your-admin-url.vercel.app

# ── Redis (Required for OTP sessions and rate limiting) ──
# Get free Redis from: https://upstash.com
REDIS_URL=rediss://default:your-token@your-redis.upstash.io:6379

# ── JWT Secret (Required) ──
# Generate random 64-character string for production:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_character_random_string_here

# ── Groq API (Required for AI Shopping Assistant) ──
# Get FREE key from: https://console.groq.com
# No credit card needed, 14,400 requests/day free
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── 2Factor.in (Optional - for SMS OTP) ──
# Get from: https://2factor.in (₹0.15 per SMS)
# Leave empty to use dev mode bypass in apps
TWOFACTOR_API_KEY=

# ── MapTiler (Required for Maps) ──
# Get FREE key from: https://cloud.maptiler.com
# Used in admin and store apps for displaying maps
MAPTILER_API_KEY=

# ── Expo Push Notifications (Optional) ──
# Only needed for push notifications via Expo
# Get from: https://expo.dev → Account → Access Tokens
EXPO_ACCESS_TOKEN=
